generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TOON
  ADMIN
  MODERATOR
  TRUSTED_CREW
  MEMBER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostType {
  EVENT
  FLYER
  PHOTO
  TEXT
  LINK
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostVisibility {
  PUBLIC
  MEMBERS_ONLY
}

enum RecommendationType {
  TRUSTED_CREW
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DisplayNameSource {
  DISCORD
  ADMIN_OVERRIDE
}

enum EventRsvpStatus {
  GOING
  MAYBE
  SADLY_NO
}

enum PostReactionType {
  LIKE
  LOVE
  HYPE
  LAUGH
  SUPPORT
}

model User {
  id                    String                    @id @default(cuid())
  name                  String?
  displayName           String?
  displayNameSource     DisplayNameSource         @default(DISCORD)
  displayNameUpdatedAt  DateTime?
  displayNameUpdatedById String?
  email                 String?                   @unique
  emailVerified         DateTime?
  image                 String?
  avatarUrl             String?
  discordId             String?                   @unique
  role                  Role                      @default(MEMBER)
  bio                   String?
  pronouns              String?
  platforms             String[]                  @default([])
  timezone              String?
  onboardingComplete    Boolean                   @default(false)
  guidelinesAcceptedAt  DateTime?
  profileSlug           String?                   @unique
  isApproved            Boolean                   @default(false)
  isBanned              Boolean                   @default(false)
  isBetaAllowed         Boolean                   @default(false)
  isActive              Boolean                   @default(true)
  accounts              Account[]
  sessions              Session[]
  officialEvents        OfficialEvent[]           @relation("OfficialEventsCreated")
  communityPosts        CommunityPost[]           @relation("CommunityPostsAuthored")
  approvedPosts         CommunityPost[]           @relation("CommunityPostsApproved")
  eventRsvps            EventRsvp[]
  postReactions         PostReaction[]
  moderatorNotes        ModeratorRecommendation[] @relation("ModeratorRecommendationsMade")
  reviewedNotes         ModeratorRecommendation[] @relation("ModeratorRecommendationsReviewed")
  recommendations       ModeratorRecommendation[] @relation("ModeratorRecommendationsForUser")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
}

model OfficialEvent {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  eventTag       String      @default("Community Event")
  eventDate      DateTime
  eventEndDate   DateTime?
  location       String
  host           String
  flyerImageUrl  String
  flyerAlt       String?
  discordUrl     String?
  rsvpUrl        String?
  isOfficial     Boolean     @default(false)
  isFeatured     Boolean     @default(false)
  status         EventStatus @default(DRAFT)
  createdById    String
  createdBy      User        @relation("OfficialEventsCreated", fields: [createdById], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  rsvps          EventRsvp[]
}

model CommunityPost {
  id            String         @id @default(cuid())
  title         String
  body          String
  postType      PostType
  imageUrl      String?
  imageAlt      String?
  externalUrl   String?
  tags          String[]
  showInGallery Boolean        @default(false)
  status        PostStatus     @default(PENDING)
  visibility    PostVisibility @default(PUBLIC)
  authorId      String
  author        User           @relation("CommunityPostsAuthored", fields: [authorId], references: [id])
  approvedById  String?
  approvedBy    User?          @relation("CommunityPostsApproved", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reactions     PostReaction[]
}

model EventRsvp {
  id        String          @id @default(cuid())
  status    EventRsvpStatus
  eventId   String
  event     OfficialEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([eventId, userId])
}

model PostReaction {
  id        String           @id @default(cuid())
  type      PostReactionType
  postId    String
  post      CommunityPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([postId, userId])
}

model ModeratorRecommendation {
  id                 String               @id @default(cuid())
  moderatorId        String
  moderator          User                 @relation("ModeratorRecommendationsMade", fields: [moderatorId], references: [id])
  userId             String
  user               User                 @relation("ModeratorRecommendationsForUser", fields: [userId], references: [id])
  recommendationType RecommendationType   @default(TRUSTED_CREW)
  reason             String
  status             RecommendationStatus @default(PENDING)
  reviewedById       String?
  reviewedBy         User?                @relation("ModeratorRecommendationsReviewed", fields: [reviewedById], references: [id])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
